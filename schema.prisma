// LeaveSync — Prisma 7 schema
// Database: PostgreSQL (Neon serverless)
// Adapter:  @prisma/adapter-neon
//
// Tenancy hierarchy:
//   Clerk Organisation (clerk_org_id)
//     └─ Organisation          (payroll entity; e.g. Acme Restaurants Pty Ltd)
//           └─ XeroConnection  (one per Organisation; one per Xero file / OAuth credential set)
//                 └─ XeroTenant (one per Xero file; carries Xero's xero_tenant_id)
//
// Key invariants:
//   - clerk_org_id maps to exactly one country_code (enforced at app layer, not DB constraint).
//   - One Organisation owns exactly one XeroConnection (unique on organisation_id).
//   - One XeroConnection owns exactly one XeroTenant (unique on xero_connection_id).
//   - One Organisation contains many People, many Feeds, many AvailabilityRecords.
//   - SyncRun is pinned to Organisation via UUID FK.
//   - clerk_org_id is present on every tenant-scoped table and indexed.
//   - All queries must filter by clerk_org_id sourced from auth().orgId.
//
// Conventions:
//   - Table names: snake_case, plural (mapped via @@map)
//   - PKs: UUID via @default(uuid())
//   - Every table: id, created_at, updated_at
//   - Soft deletes where specified: archived_at (nullable timestamp)
//   - Enums defined at database level
//   - JSON columns carry a comment referencing the Zod schema used to validate them

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum CountryCode {
  AU
  NZ
  UK
}

enum PersonType {
  employee
  contractor
  director
  offshore_staff
}

enum SourceSystem {
  xero
  manual
}

enum ContactabilityStatus {
  contactable
  limited
  not_contactable
  use_alternative_contact
}

enum PrivacyMode {
  named
  masked
  private
}

enum XeroConnectionStatus {
  active
  expired
  revoked
  error
}

enum XeroTenantStatus {
  active
  paused
  disconnected
}

enum PayrollRegion {
  AU
  NZ
  UK
}

enum SyncEntityType {
  employees
  leave_records
  leave_balances
  leave_periods
}

enum SyncCursorStatus {
  idle
  running
  failed
}

enum SourceType {
  xero_leave
  leavesync_leave
  manual
}

enum RecordType {
  annual_leave
  personal_leave
  holiday
  sick_leave
  long_service_leave
  unpaid_leave
  public_holiday
  wfh
  travelling
  client_site
  another_office
  training
  offsite_meeting
  contractor_unavailable
  limited_availability
  alternative_contact
  other
  leave_request
}

enum PublishStatus {
  eligible
  suppressed
  archived
}

enum ApprovalStatus {
  draft
  submitted
  approved
  declined
  withdrawn
  xero_sync_failed
}

enum BalanceUnit {
  hours
  days
}

enum HolidayType {
  national
  regional
  custom
}

enum HolidaySource {
  api
  manual
}

enum NotificationType {
  sync_completed
  sync_failed
  sync_partial
  feed_token_rotated
  privacy_conflict
  missing_alternative_contact
  leave_submitted
  leave_approved
  leave_declined
  leave_withdrawn
  leave_xero_sync_failed
  leave_peak_warning
  plan_confirmed
}

enum FeedScopeType {
  all_staff
  team
  manager
  location
  event_type
  custom
}

enum FeedStatus {
  active
  paused
  archived
}

enum FeedTokenStatus {
  active
  revoked
  expired
}

enum FeedScopeRuleType {
  organisation
  team
  manager
  location
  event_type
  person
}

enum SyncRunType {
  initial
  incremental
  reconciliation
  manual
}

enum SyncRunStatus {
  queued
  running
  partial
  succeeded
  failed
  dead_lettered
}

enum AuditActorType {
  user
  system
  sync
}

enum PlanLimitType {
  active_people
  connections
  feeds
  organisations
}

enum SubscriptionStatus {
  active
  cancelled
  past_due
}

enum UsageCounterType {
  active_people
  connections
  feeds
  sync_runs
}

// ---------------------------------------------------------------------------
// Organisations
// ---------------------------------------------------------------------------

/// A payroll entity within a Clerk Organisation.
/// Examples under one clerk_org_id: "Acme Restaurants Pty Ltd", "Acme Hotels Pty Ltd".
/// country_code is uniform across all Organisations sharing a clerk_org_id (app-layer invariant).
model Organisation {
  id           String      @id @default(uuid())
  clerk_org_id String
  name         String
  country_code CountryCode
  timezone     String      // IANA timezone; e.g. Australia/Brisbane
  is_active    Boolean     @default(true)
  created_at   DateTime    @default(now())
  updated_at   DateTime    @updatedAt

  xero_connection          XeroConnection?
  teams                    Team[]
  locations                Location[]
  people                   Person[]
  availability_records     AvailabilityRecord[]
  leave_balances           LeaveBalance[]
  public_holidays          PublicHoliday[]
  feeds                    Feed[]
  sync_runs                SyncRun[]
  audit_events             AuditEvent[]
  notifications            Notification[]
  notification_preferences NotificationPreference[]

  @@index([clerk_org_id])
  @@map("organisations")
}

// ---------------------------------------------------------------------------
// Teams
// ---------------------------------------------------------------------------

model Team {
  id                String   @id @default(uuid())
  clerk_org_id      String
  organisation_id   String
  name              String
  manager_person_id String?
  created_at        DateTime @default(now())
  updated_at        DateTime @updatedAt

  organisation Organisation @relation(fields: [organisation_id], references: [id])
  manager      Person?      @relation("TeamManager", fields: [manager_person_id], references: [id])
  members      Person[]     @relation("TeamMembers")

  @@index([clerk_org_id])
  @@index([organisation_id])
  @@map("teams")
}

// ---------------------------------------------------------------------------
// Locations
// ---------------------------------------------------------------------------

model Location {
  id              String   @id @default(uuid())
  clerk_org_id    String
  organisation_id String
  name            String
  country_code    String
  region_code     String?  // e.g. QLD, Auckland, Scotland
  timezone        String   // IANA timezone
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  organisation    Organisation    @relation(fields: [organisation_id], references: [id])
  public_holidays PublicHoliday[]

  @@index([clerk_org_id])
  @@index([organisation_id])
  @@map("locations")
}

// ---------------------------------------------------------------------------
// People
// ---------------------------------------------------------------------------

/// Covers employees, contractors, directors, and offshore staff.
/// source_system = xero:   synced from Xero Payroll via the Organisation's XeroConnection.
/// source_system = manual: created directly in LeaveSync.
/// source_person_key:      Xero employee ID; null for manual entries.
model Person {
  id                          String               @id @default(uuid())
  clerk_org_id                String
  organisation_id             String
  team_id                     String?
  manager_person_id           String?
  person_type                 PersonType
  source_system               SourceSystem
  source_person_key           String?
  display_name                String
  first_name                  String
  last_name                   String
  email                       String
  phone                       String?
  job_title                   String?
  is_active                   Boolean              @default(true)
  default_contactability      ContactabilityStatus @default(contactable)
  default_contact_method      String?
  default_privacy_mode        PrivacyMode          @default(named)
  include_in_feeds_by_default Boolean              @default(true)
  created_at                  DateTime             @default(now())
  updated_at                  DateTime             @updatedAt

  organisation         Organisation         @relation(fields: [organisation_id], references: [id])
  team                 Team?                @relation("TeamMembers", fields: [team_id], references: [id])
  manager              Person?              @relation("Reports", fields: [manager_person_id], references: [id])
  direct_reports       Person[]             @relation("Reports")
  managed_teams        Team[]               @relation("TeamManager")
  alternative_contacts AlternativeContact[]
  availability_records AvailabilityRecord[]
  leave_balances       LeaveBalance[]
  approved_records     AvailabilityRecord[] @relation("ApprovedBy")

  // Xero employee key must be unique within one Organisation.
  @@unique([organisation_id, source_system, source_person_key])
  @@index([clerk_org_id])
  @@index([organisation_id])
  @@map("people")
}

// ---------------------------------------------------------------------------
// Alternative contacts
// ---------------------------------------------------------------------------

model AlternativeContact {
  id             String   @id @default(uuid())
  person_id      String
  name           String
  contact_method String
  contact_value  String
  priority       Int
  is_default     Boolean  @default(false)
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  person               Person               @relation(fields: [person_id], references: [id])
  availability_records AvailabilityRecord[]

  @@index([person_id])
  @@map("alternative_contacts")
}

// ---------------------------------------------------------------------------
// Xero connections
// ---------------------------------------------------------------------------

/// One row per Organisation (one per Xero file / OAuth credential set).
/// Scenario A: current-state table. Historical connection lifecycle is captured in audit_events.
/// Tokens are encrypted at rest before storage; never stored in plaintext.
model XeroConnection {
  id                      String               @id @default(uuid())
  clerk_org_id            String
  organisation_id         String               @unique // one connection per Organisation
  provider                String               @default("xero")
  status                  XeroConnectionStatus @default(active)
  access_token_encrypted  String
  refresh_token_encrypted String
  expires_at              DateTime
  created_at              DateTime             @default(now())
  updated_at              DateTime             @updatedAt

  organisation Organisation @relation(fields: [organisation_id], references: [id])
  xero_tenant  XeroTenant?

  @@index([clerk_org_id])
  @@map("xero_connections")
}

// ---------------------------------------------------------------------------
// Xero tenants
// ---------------------------------------------------------------------------

/// One row per connected Xero file (one per XeroConnection).
/// payroll_region determines which Xero Payroll API is used for all sync and write operations.
/// xero_tenant_id is Xero's own identifier for the connected organisation.
model XeroTenant {
  id                      String           @id @default(uuid())
  clerk_org_id            String
  xero_connection_id      String           @unique // one tenant per connection
  organisation_id         String
  xero_tenant_id          String           // Xero's own tenant identifier
  tenant_name             String
  payroll_region          PayrollRegion
  status                  XeroTenantStatus @default(active)
  last_employee_sync_at   DateTime?
  last_leave_sync_at      DateTime?
  last_balance_sync_at    DateTime?
  last_successful_sync_at DateTime?
  created_at              DateTime         @default(now())
  updated_at              DateTime         @updatedAt

  xero_connection XeroConnection   @relation(fields: [xero_connection_id], references: [id])
  sync_cursors    XeroSyncCursor[]
  sync_runs       SyncRun[]
  leave_balances  LeaveBalance[]

  @@index([clerk_org_id])
  @@index([organisation_id])
  @@index([xero_tenant_id])
  @@map("xero_tenants")
}

// ---------------------------------------------------------------------------
// Xero sync cursors
// ---------------------------------------------------------------------------

/// Tracks incremental sync state per entity type per Xero tenant.
/// One row per (xero_tenant_id, entity_type) pair; updated in place.
model XeroSyncCursor {
  id                          String           @id @default(uuid())
  xero_tenant_id              String
  entity_type                 SyncEntityType
  cursor_value                String?
  last_seen_remote_updated_at DateTime?
  last_full_sync_at           DateTime?
  last_incremental_sync_at    DateTime?
  sync_status                 SyncCursorStatus @default(idle)
  error_message               String?
  created_at                  DateTime         @default(now())
  updated_at                  DateTime         @updatedAt

  xero_tenant XeroTenant @relation(fields: [xero_tenant_id], references: [id])

  @@unique([xero_tenant_id, entity_type])
  @@index([xero_tenant_id, entity_type])
  @@map("xero_sync_cursors")
}

// ---------------------------------------------------------------------------
// Availability records
// ---------------------------------------------------------------------------

/// Core domain object. Holds both Xero-synced leave and manual availability entries.
/// Not called a "leave application". Record type covers the full range defined in RecordType.
///
/// source_payload_json:  raw Xero API response retained for audit.
///                       Zod schema: XeroLeavePayloadSchema (packages/xero/src/types).
/// xero_write_error_raw: raw Xero API error payload for admin audit only.
///                       Zod schema: XeroWriteErrorSchema (packages/xero/src/errors).
///                       Never displayed to employees; plain-language version in xero_write_error.
/// derived_uid_key:      stable ICS UID computed per the deterministic hash formula in PRODUCT.md.
model AvailabilityRecord {
  id                       String               @id @default(uuid())
  clerk_org_id             String
  organisation_id          String
  person_id                String
  source_type              SourceType
  record_type              RecordType
  title                    String
  starts_at                DateTime
  ends_at                  DateTime
  all_day                  Boolean              @default(false)
  working_location         String?
  contactability_status    ContactabilityStatus @default(contactable)
  preferred_contact_method String?
  alternative_contact_id   String?
  notes_internal           String?
  include_in_feed          Boolean              @default(true)
  privacy_mode             PrivacyMode          @default(named)
  publish_status           PublishStatus        @default(eligible)
  source_remote_id         String?              // Xero leave application ID
  source_remote_hash       String?              // fingerprint for change detection
  source_remote_version    String?
  source_last_modified_at  DateTime?
  source_payload_json      Json?                // see XeroLeavePayloadSchema
  derived_uid_key          String               // stable ICS UID; see PRODUCT.md UID strategy
  created_by_user_id       String?              // Clerk user ID
  updated_by_user_id       String?              // Clerk user ID
  created_at               DateTime             @default(now())
  updated_at               DateTime             @updatedAt
  archived_at              DateTime?
  approval_status          ApprovalStatus       @default(draft)
  approval_note            String?
  approved_by_person_id    String?
  approved_at              DateTime?
  xero_write_error         String?              // plain-language error for display
  xero_write_error_raw     Json?                // see XeroWriteErrorSchema; admin audit only
  submitted_at             DateTime?
  withdrawn_at             DateTime?

  organisation        Organisation             @relation(fields: [organisation_id], references: [id])
  person              Person                   @relation(fields: [person_id], references: [id])
  approved_by         Person?                  @relation("ApprovedBy", fields: [approved_by_person_id], references: [id])
  alternative_contact AlternativeContact?      @relation(fields: [alternative_contact_id], references: [id])
  publication         AvailabilityPublication?

  // Xero-sourced records must be unique per Organisation + source identity.
  @@unique([organisation_id, source_type, source_remote_id])
  @@index([clerk_org_id])
  @@index([person_id, starts_at, ends_at])
  @@index([organisation_id, publish_status, include_in_feed])
  @@index([source_type, source_last_modified_at])
  @@map("availability_records")
}

// ---------------------------------------------------------------------------
// Availability publications
// ---------------------------------------------------------------------------

/// Materialised publishing state per AvailabilityRecord.
/// Decouples raw availability data from what was actually emitted in a feed.
/// published_sequence is incremented when the published representation changes materially.
model AvailabilityPublication {
  id                     String   @id @default(uuid())
  availability_record_id String   @unique
  published_title        String
  published_description  String?
  published_location     String?
  published_status       String
  published_uid          String   // deterministic ICS UID
  published_sequence     Int      @default(0)
  published_dtstamp      DateTime
  last_published_at      DateTime
  last_feed_hash         String?
  created_at             DateTime @default(now())
  updated_at             DateTime @updatedAt

  availability_record AvailabilityRecord @relation(fields: [availability_record_id], references: [id])

  @@map("availability_publications")
}

// ---------------------------------------------------------------------------
// Leave balances
// ---------------------------------------------------------------------------

/// Fetched from Xero per person per leave type. Never calculated by LeaveSync.
/// Updated in place on each balance sync run.
model LeaveBalance {
  id                 String      @id @default(uuid())
  clerk_org_id       String
  organisation_id    String
  person_id          String
  xero_tenant_id     String
  leave_type_xero_id String      // Xero's leave type identifier
  leave_type_name    String      // display name from Xero
  record_type        RecordType  // canonical mapping
  balance_value      Decimal     @db.Decimal(10, 4)
  balance_unit       BalanceUnit
  as_at              DateTime    // timestamp of the Xero fetch
  created_at         DateTime    @default(now())
  updated_at         DateTime    @updatedAt

  organisation Organisation @relation(fields: [organisation_id], references: [id])
  person       Person       @relation(fields: [person_id], references: [id])
  xero_tenant  XeroTenant   @relation(fields: [xero_tenant_id], references: [id])

  @@unique([person_id, xero_tenant_id, leave_type_xero_id])
  @@index([clerk_org_id])
  @@index([person_id])
  @@map("leave_balances")
}

// ---------------------------------------------------------------------------
// Public holidays
// ---------------------------------------------------------------------------

/// Sourced from Nager.Date API or entered manually by admins.
/// location_id = null means the holiday applies to all locations in the Organisation.
/// The unique constraint covers all rows; the app layer skips insert for source = manual
/// when an identical custom holiday already exists.
model PublicHoliday {
  id              String        @id @default(uuid())
  clerk_org_id    String
  organisation_id String
  location_id     String?
  name            String
  date            DateTime      @db.Date
  observed_date   DateTime?     @db.Date
  country_code    CountryCode
  region_code     String?       // e.g. QLD, Auckland, Scotland
  holiday_type    HolidayType
  source          HolidaySource
  is_suppressed   Boolean       @default(false)
  recurs_annually Boolean       @default(false)
  created_at      DateTime      @default(now())
  updated_at      DateTime      @updatedAt

  organisation Organisation @relation(fields: [organisation_id], references: [id])
  location     Location?    @relation(fields: [location_id], references: [id])

  @@unique([organisation_id, location_id, date, source])
  @@index([clerk_org_id])
  @@index([organisation_id, date])
  @@map("public_holidays")
}

// ---------------------------------------------------------------------------
// Notifications
// ---------------------------------------------------------------------------

/// In-app notifications delivered via SSE. Per-user, per-Clerk-Organisation.
/// SSE connections must not leak notifications across clerk_org_id boundaries.
model Notification {
  id                String           @id @default(uuid())
  clerk_org_id      String
  organisation_id   String
  recipient_user_id String           // Clerk user ID
  notification_type NotificationType
  title             String
  body              String
  entity_type       String?          // e.g. availability_record
  entity_id         String?
  action_url        String?
  is_read           Boolean          @default(false)
  read_at           DateTime?
  created_at        DateTime         @default(now())

  organisation Organisation @relation(fields: [organisation_id], references: [id])

  @@index([clerk_org_id])
  @@index([recipient_user_id, is_read])
  @@index([recipient_user_id, created_at])
  @@map("notifications")
}

// ---------------------------------------------------------------------------
// Notification preferences
// ---------------------------------------------------------------------------

/// Per-user, per-Clerk-Organisation opt-in settings.
/// Defaults: in_app_enabled = true, email_enabled = true for all notification types.
model NotificationPreference {
  id                String           @id @default(uuid())
  user_id           String           // Clerk user ID
  clerk_org_id      String
  organisation_id   String
  notification_type NotificationType
  in_app_enabled    Boolean          @default(true)
  email_enabled     Boolean          @default(true)
  created_at        DateTime         @default(now())
  updated_at        DateTime         @updatedAt

  organisation Organisation @relation(fields: [organisation_id], references: [id])

  @@unique([user_id, clerk_org_id, notification_type])
  @@index([clerk_org_id])
  @@map("notification_preferences")
}

// ---------------------------------------------------------------------------
// Feeds
// ---------------------------------------------------------------------------

/// ICS calendar feeds. Scoped to a Clerk Organisation; optionally narrowed to one Organisation.
/// organisation_id is nullable to allow a feed that spans all payroll entities in a Clerk Org.
model Feed {
  id                     String        @id @default(uuid())
  clerk_org_id           String
  organisation_id        String?       // null = spans all Organisations in the Clerk Org
  name                   String
  slug                   String
  scope_type             FeedScopeType
  privacy_default        PrivacyMode   @default(named)
  include_contractors    Boolean       @default(false)
  include_directors      Boolean       @default(false)
  include_offshore_staff Boolean       @default(false)
  status                 FeedStatus    @default(active)
  last_rendered_at       DateTime?
  last_etag              String?
  created_at             DateTime      @default(now())
  updated_at             DateTime      @updatedAt

  organisation Organisation? @relation(fields: [organisation_id], references: [id])
  scopes       FeedScope[]
  tokens       FeedToken[]

  @@unique([clerk_org_id, slug])
  @@index([clerk_org_id])
  @@map("feeds")
}

// ---------------------------------------------------------------------------
// Feed scopes
// ---------------------------------------------------------------------------

model FeedScope {
  id         String            @id @default(uuid())
  feed_id    String
  rule_type  FeedScopeRuleType
  rule_value String
  created_at DateTime          @default(now())

  feed Feed @relation(fields: [feed_id], references: [id])

  @@index([feed_id, rule_type, rule_value])
  @@map("feed_scopes")
}

// ---------------------------------------------------------------------------
// Feed tokens
// ---------------------------------------------------------------------------

/// Signed, revocable tokens for ICS feed access.
/// token_hash is stored; the plaintext token is never persisted.
/// rotated_from_token_id provides a rotation audit trail within this table.
model FeedToken {
  id                    String          @id @default(uuid())
  feed_id               String
  token_hash            String
  token_hint            String          // last four characters; shown in UI
  status                FeedTokenStatus @default(active)
  rotated_from_token_id String?
  expires_at            DateTime?
  last_accessed_at      DateTime?
  created_at            DateTime        @default(now())

  feed         Feed        @relation(fields: [feed_id], references: [id])
  rotated_from FeedToken?  @relation("TokenRotation", fields: [rotated_from_token_id], references: [id])
  rotated_into FeedToken[] @relation("TokenRotation")

  @@index([feed_id])
  @@index([token_hash])
  @@map("feed_tokens")
}

// ---------------------------------------------------------------------------
// Sync runs
// ---------------------------------------------------------------------------

/// One row per sync execution.
/// Pinned to Organisation via UUID FK and to XeroTenant for the specific Xero file synced.
model SyncRun {
  id              String        @id @default(uuid())
  clerk_org_id    String
  organisation_id String
  xero_tenant_id  String
  run_type        SyncRunType
  status          SyncRunStatus @default(queued)
  started_at      DateTime
  finished_at     DateTime?
  records_in      Int           @default(0)
  records_changed Int           @default(0)
  records_failed  Int           @default(0)
  error_summary   String?
  retry_count     Int           @default(0)
  created_at      DateTime      @default(now())

  organisation   Organisation   @relation(fields: [organisation_id], references: [id])
  xero_tenant    XeroTenant     @relation(fields: [xero_tenant_id], references: [id])
  failed_records FailedRecord[]

  @@index([clerk_org_id])
  @@index([organisation_id])
  @@index([xero_tenant_id])
  @@map("sync_runs")
}

// ---------------------------------------------------------------------------
// Failed records
// ---------------------------------------------------------------------------

/// Dead-letter table for individual record failures within a sync run.
/// source_payload_json contains the raw payload that caused the failure.
/// Zod schema varies by entity_type; see packages/xero/src/types for the relevant schema.
model FailedRecord {
  id                  String   @id @default(uuid())
  sync_run_id         String
  entity_type         String
  source_remote_id    String?
  error_message       String
  source_payload_json Json?
  created_at          DateTime @default(now())

  sync_run SyncRun @relation(fields: [sync_run_id], references: [id])

  @@index([sync_run_id])
  @@map("failed_records")
}

// ---------------------------------------------------------------------------
// Audit events
// ---------------------------------------------------------------------------

/// Full lifecycle audit log for admin actions, sync events, and system changes.
/// old_values_json / new_values_json: arbitrary entity snapshots; no fixed Zod schema.
/// organisation_id is nullable to cover Clerk-Org-level events (e.g. OAuth connection changes).
model AuditEvent {
  id              String         @id @default(uuid())
  clerk_org_id    String
  organisation_id String?
  actor_user_id   String?        // Clerk user ID; null for system and sync actors
  actor_type      AuditActorType
  entity_type     String
  entity_id       String
  action          String
  old_values_json Json?
  new_values_json Json?
  reason          String?
  created_at      DateTime       @default(now())

  organisation Organisation? @relation(fields: [organisation_id], references: [id])

  @@index([clerk_org_id])
  @@index([entity_type, entity_id, created_at])
  @@map("audit_events")
}

// ---------------------------------------------------------------------------
// Billing
// ---------------------------------------------------------------------------

/// Plans define feature limits enforced at the Clerk Organisation level.
model Plan {
  id         String   @id @default(uuid())
  name       String   // free, starter, pro, enterprise
  is_active  Boolean  @default(true)
  created_at DateTime @default(now())

  limits                  PlanLimit[]
  clerk_org_subscriptions ClerkOrgSubscription[]

  @@map("plans")
}

model PlanLimit {
  id          String        @id @default(uuid())
  plan_id     String
  limit_type  PlanLimitType
  limit_value Int

  plan Plan @relation(fields: [plan_id], references: [id])

  @@unique([plan_id, limit_type])
  @@map("plan_limits")
}

/// Billing anchor at Clerk Organisation level.
/// One subscription per Clerk Organisation (unique on clerk_org_id).
model ClerkOrgSubscription {
  id           String             @id @default(uuid())
  clerk_org_id String             @unique
  plan_id      String
  status       SubscriptionStatus @default(active)
  started_at   DateTime
  expires_at   DateTime?
  created_at   DateTime           @default(now())
  updated_at   DateTime           @updatedAt

  plan           Plan           @relation(fields: [plan_id], references: [id])
  usage_counters UsageCounter[]

  @@map("clerk_org_subscriptions")
}

/// Usage counters per Clerk Organisation per counter type.
/// Updated in place; significant threshold events are captured in audit_events.
model UsageCounter {
  id              String           @id @default(uuid())
  clerk_org_id    String
  subscription_id String
  counter_type    UsageCounterType
  counter_value   Int              @default(0)
  updated_at      DateTime         @updatedAt

  subscription ClerkOrgSubscription @relation(fields: [subscription_id], references: [id])

  @@unique([clerk_org_id, counter_type])
  @@index([clerk_org_id])
  @@map("usage_counters")
}
