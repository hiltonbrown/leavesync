generator client {
  provider        = "prisma-client"
  output          = "../generated"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

enum source_system {
  XERO
  MANUAL
}

enum employment_type {
  employee
  contractor
  director
  offshore
}

enum person_type {
  employee
  contractor
  director
  offshore_staff
}

enum payroll_region {
  AU
  NZ
  UK
}

enum xero_sync_entity_type {
  people
  leave_records
  leave_balances
}

enum availability_record_type {
  leave
  annual_leave
  personal_leave
  holiday
  sick_leave
  long_service_leave
  unpaid_leave
  public_holiday
  wfh
  travel
  travelling
  training
  client_site
  another_office
  offsite_meeting
  contractor_unavailable
  limited_availability
  alternative_contact
  other
  leave_request
}

enum availability_source_type {
  xero
  xero_leave
  leavesync_leave
  manual
}

enum availability_approval_status {
  draft
  submitted
  approved
  declined
  cancelled
  withdrawn
  xero_sync_failed
}

enum availability_failed_action {
  submit
  approve
  decline
  withdraw
}

enum availability_privacy_mode {
  named
  masked
  private
}

enum availability_contactability {
  contactable
  limited
  unavailable
  use_alternative_contact
}

enum availability_publish_status {
  eligible
  suppressed
  archived
}

enum leave_balance_unit {
  hours
  days
}

enum feed_scope_rule_type {
  person
  team
  location
  organisation
}

enum feed_status {
  active
  paused
  archived
}

enum feed_token_status {
  active
  revoked
  expired
}

enum notification_type {
  sync_failed
  feed_token_rotated
  privacy_conflict
  missing_alternative_contact
  leave_submitted
  leave_approved
  leave_declined
  leave_info_requested
  leave_xero_sync_failed
  leave_withdrawn
}

enum public_holiday_source {
  nager
  manual
}

enum public_holiday_type {
  public
  bank
  school
  authorities
  optional
  observance
  closure
  custom
}

enum public_holiday_assignment_scope_type {
  organisation
  location
  team
  person
  feed
}

enum public_holiday_day_classification {
  non_working
  working
}

model Organisation {
  id                    String    @id @default(uuid()) @db.Uuid
  clerk_org_id          String
  name                  String
  country_code          String
  is_active             Boolean   @default(true)
  timezone              String?
  locale                String?
  fiscal_year_start     Int?
  working_hours_per_day Decimal?  @db.Decimal(4, 2)
  reporting_unit        String?
  archived_at           DateTime?
  created_at            DateTime  @default(now())
  updated_at            DateTime  @updatedAt

  teams                        Team[]
  locations                    Location[]
  people                       Person[]
  leave_balances               LeaveBalance[]
  alternative_contacts         AlternativeContact[]
  availability_records         AvailabilityRecord[]
  availability_publications    AvailabilityPublication[]
  feeds                        Feed[]
  public_holiday_jurisdictions PublicHolidayJurisdiction[]
  public_holidays              PublicHoliday[]
  public_holiday_assignments   PublicHolidayAssignment[]
  xero_connection              XeroConnection?
  xero_tenants                 XeroTenant[]
  xero_sync_cursors            XeroSyncCursor[]
  sync_runs                    SyncRun[]
  failed_records               FailedRecord[]
  audit_events                 AuditEvent[]

  @@index([clerk_org_id])
  @@map("organisations")
}

model Team {
  id              String   @id @default(uuid()) @db.Uuid
  clerk_org_id    String
  organisation_id String   @db.Uuid
  name            String
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  organisation Organisation @relation(fields: [organisation_id], references: [id])
  people       Person[]

  @@index([clerk_org_id])
  @@index([organisation_id])
  @@map("teams")
}

model Location {
  id              String   @id @default(uuid()) @db.Uuid
  clerk_org_id    String
  organisation_id String   @db.Uuid
  name            String
  country_code    String?
  region_code     String?
  timezone        String?
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  organisation Organisation @relation(fields: [organisation_id], references: [id])
  people       Person[]

  @@index([clerk_org_id])
  @@index([organisation_id])
  @@map("locations")
}

model Person {
  id                          String                      @id @default(uuid()) @db.Uuid
  clerk_org_id                String
  organisation_id             String                      @db.Uuid
  team_id                     String?                     @db.Uuid
  manager_person_id           String?                     @db.Uuid
  location_id                 String?                     @db.Uuid
  person_type                 person_type?
  source_system               source_system
  source_person_key           String?
  first_name                  String
  last_name                   String
  email                       String
  xero_employee_id            String?
  employment_type             employment_type
  is_active                   Boolean                     @default(true)
  display_name                String?
  clerk_user_id               String?
  job_title                   String?
  start_date                  DateTime?
  avatar_url                  String?
  status_note                 String?
  default_contactability      availability_contactability @default(contactable)
  default_privacy_mode        availability_privacy_mode   @default(named)
  include_in_feeds_by_default Boolean                     @default(true)
  archived_at                 DateTime?
  created_at                  DateTime                    @default(now())
  updated_at                  DateTime                    @updatedAt

  organisation         Organisation         @relation(fields: [organisation_id], references: [id])
  team                 Team?                @relation(fields: [team_id], references: [id])
  location             Location?            @relation(fields: [location_id], references: [id])
  manager              Person?              @relation("PersonManager", fields: [manager_person_id], references: [id])
  direct_reports       Person[]             @relation("PersonManager")
  leave_balances       LeaveBalance[]
  alternative_contacts AlternativeContact[]
  availability_records AvailabilityRecord[]
  approved_records     AvailabilityRecord[] @relation("ApprovedBy")

  @@unique([organisation_id, source_system, source_person_key])
  @@unique([organisation_id, clerk_user_id])
  @@unique([organisation_id, xero_employee_id])
  @@index([clerk_org_id])
  @@index([organisation_id])
  @@index([organisation_id, team_id])
  @@index([organisation_id, manager_person_id])
  @@index([team_id])
  @@index([location_id])
  @@map("people")
}

model AlternativeContact {
  id              String   @id @default(uuid()) @db.Uuid
  clerk_org_id    String
  organisation_id String   @db.Uuid
  person_id       String   @db.Uuid
  name            String
  role            String?
  email           String?
  phone           String?
  notes           String?
  display_order   Int
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  organisation Organisation @relation(fields: [organisation_id], references: [id])
  person       Person       @relation(fields: [person_id], references: [id])

  @@index([clerk_org_id])
  @@index([organisation_id])
  @@index([person_id])
  @@index([person_id, display_order])
  @@map("alternative_contacts")
}

model XeroConnection {
  id                      String    @id @default(uuid()) @db.Uuid
  clerk_org_id            String
  organisation_id         String    @unique @db.Uuid
  access_token_encrypted  String
  refresh_token_encrypted String
  expires_at              DateTime
  revoked_at              DateTime?
  created_at              DateTime  @default(now())
  updated_at              DateTime  @updatedAt

  organisation Organisation @relation(fields: [organisation_id], references: [id])
  xero_tenant  XeroTenant?

  @@index([clerk_org_id])
  @@map("xero_connections")
}

model XeroTenant {
  id                 String         @id @default(uuid()) @db.Uuid
  clerk_org_id       String
  organisation_id    String         @db.Uuid
  xero_connection_id String         @unique @db.Uuid
  xero_tenant_id     String
  payroll_region     payroll_region
  created_at         DateTime       @default(now())
  updated_at         DateTime       @updatedAt

  organisation    Organisation     @relation(fields: [organisation_id], references: [id])
  xero_connection XeroConnection   @relation(fields: [xero_connection_id], references: [id])
  sync_cursors    XeroSyncCursor[]
  leave_balances  LeaveBalance[]

  @@index([clerk_org_id])
  @@index([organisation_id])
  @@index([xero_tenant_id])
  @@map("xero_tenants")
}

model XeroSyncCursor {
  id              String                @id @default(uuid()) @db.Uuid
  clerk_org_id    String
  organisation_id String                @db.Uuid
  xero_tenant_id  String                @db.Uuid
  entity_type     xero_sync_entity_type
  cursor_value    String?
  created_at      DateTime              @default(now())
  updated_at      DateTime              @updatedAt

  organisation Organisation @relation(fields: [organisation_id], references: [id])
  xero_tenant  XeroTenant   @relation(fields: [xero_tenant_id], references: [id])

  @@unique([xero_tenant_id, entity_type])
  @@index([clerk_org_id])
  @@index([organisation_id])
  @@index([xero_tenant_id])
  @@map("xero_sync_cursors")
}

model AvailabilityRecord {
  id                       String                       @id @default(uuid()) @db.Uuid
  clerk_org_id             String
  organisation_id          String                       @db.Uuid
  person_id                String                       @db.Uuid
  record_type              availability_record_type
  source_type              availability_source_type
  source_remote_id         String?
  starts_at                DateTime
  ends_at                  DateTime
  approval_status          availability_approval_status
  failed_action            availability_failed_action?
  privacy_mode             availability_privacy_mode
  contactability           availability_contactability
  include_in_feed          Boolean                      @default(true)
  publish_status           availability_publish_status  @default(eligible)
  source_payload_json      Json?
  source_remote_hash       String?
  source_remote_version    String?
  source_last_modified_at  DateTime?
  derived_uid_key          String
  derived_sequence         Int                          @default(0)
  title                    String?
  all_day                  Boolean                      @default(true)
  notes_internal           String?
  working_location         String?
  preferred_contact_method String?
  created_by_user_id       String?
  updated_by_user_id       String?
  archived_at              DateTime?
  approval_note            String?
  approved_by_person_id    String?                      @db.Uuid
  approved_at              DateTime?
  xero_write_error         String?
  xero_write_error_raw     Json?
  submitted_at             DateTime?
  withdrawn_at             DateTime?
  created_at               DateTime                     @default(now())
  updated_at               DateTime                     @updatedAt

  organisation Organisation             @relation(fields: [organisation_id], references: [id])
  person       Person                   @relation(fields: [person_id], references: [id])
  approved_by  Person?                  @relation("ApprovedBy", fields: [approved_by_person_id], references: [id])
  publication  AvailabilityPublication?

  @@unique([organisation_id, source_type, source_remote_id], map: "availability_records_source_identity_key")
  @@index([clerk_org_id])
  @@index([organisation_id])
  @@index([person_id, starts_at, ends_at])
  @@index([approved_by_person_id])
  @@index([source_type, source_remote_id])
  @@index([organisation_id, publish_status, include_in_feed])
  @@index([source_type, source_last_modified_at])
  @@map("availability_records")
}

model AvailabilityPublication {
  id                     String                    @id @default(uuid()) @db.Uuid
  clerk_org_id           String
  organisation_id        String                    @db.Uuid
  availability_record_id String                    @unique @db.Uuid
  published_uid          String
  published_summary      String
  published_description  String?
  published_sequence     Int                       @default(0)
  published_at           DateTime
  privacy_mode           availability_privacy_mode
  created_at             DateTime                  @default(now())
  updated_at             DateTime                  @updatedAt

  organisation        Organisation       @relation(fields: [organisation_id], references: [id])
  availability_record AvailabilityRecord @relation(fields: [availability_record_id], references: [id])

  @@index([clerk_org_id])
  @@index([organisation_id])
  @@index([published_uid])
  @@map("availability_publications")
}

model LeaveBalance {
  id                 String                    @id @default(uuid()) @db.Uuid
  clerk_org_id       String
  organisation_id    String                    @db.Uuid
  person_id          String                    @db.Uuid
  xero_tenant_id     String                    @db.Uuid
  leave_type_xero_id String
  leave_type_name    String?
  record_type        availability_record_type?
  balance            Decimal                   @db.Decimal(12, 4)
  balance_unit       leave_balance_unit?
  as_at              DateTime?
  last_fetched_at    DateTime?
  created_at         DateTime                  @default(now())
  updated_at         DateTime                  @updatedAt

  organisation Organisation @relation(fields: [organisation_id], references: [id])
  person       Person       @relation(fields: [person_id], references: [id])
  xero_tenant  XeroTenant   @relation(fields: [xero_tenant_id], references: [id])

  @@unique([person_id, xero_tenant_id, leave_type_xero_id])
  @@index([clerk_org_id])
  @@index([organisation_id])
  @@index([person_id])
  @@index([xero_tenant_id])
  @@map("leave_balances")
}

model PublicHolidayJurisdiction {
  id                 String                @id @default(uuid()) @db.Uuid
  clerk_org_id       String
  organisation_id    String                @db.Uuid
  country_code       String
  region_code        String?
  source             public_holiday_source @default(nager)
  is_enabled         Boolean               @default(true)
  created_by_user_id String?
  updated_by_user_id String?
  archived_at        DateTime?
  created_at         DateTime              @default(now())
  updated_at         DateTime              @updatedAt

  organisation Organisation    @relation(fields: [organisation_id], references: [id])
  holidays     PublicHoliday[]

  @@unique([organisation_id, country_code, region_code])
  @@index([clerk_org_id])
  @@index([organisation_id])
  @@map("public_holiday_jurisdictions")
}

model PublicHoliday {
  id                     String                            @id @default(uuid()) @db.Uuid
  clerk_org_id           String
  organisation_id        String                            @db.Uuid
  jurisdiction_id        String?                           @db.Uuid
  source                 public_holiday_source
  source_remote_id       String?
  country_code           String
  region_code            String?
  holiday_date           DateTime
  name                   String
  local_name             String?
  holiday_type           public_holiday_type
  default_classification public_holiday_day_classification @default(non_working)
  notes_internal         String?
  source_payload_json    Json?
  created_by_user_id     String?
  updated_by_user_id     String?
  archived_at            DateTime?
  created_at             DateTime                          @default(now())
  updated_at             DateTime                          @updatedAt

  organisation Organisation               @relation(fields: [organisation_id], references: [id])
  jurisdiction PublicHolidayJurisdiction? @relation(fields: [jurisdiction_id], references: [id])
  assignments  PublicHolidayAssignment[]

  @@unique([organisation_id, source, source_remote_id])
  @@index([clerk_org_id])
  @@index([organisation_id, holiday_date])
  @@index([jurisdiction_id])
  @@map("public_holidays")
}

model PublicHolidayAssignment {
  id                 String                               @id @default(uuid()) @db.Uuid
  clerk_org_id       String
  organisation_id    String                               @db.Uuid
  public_holiday_id  String                               @db.Uuid
  scope_type         public_holiday_assignment_scope_type
  scope_value        String
  day_classification public_holiday_day_classification    @default(non_working)
  include_in_feeds   Boolean                              @default(true)
  notes_internal     String?
  created_by_user_id String?
  updated_by_user_id String?
  archived_at        DateTime?
  created_at         DateTime                             @default(now())
  updated_at         DateTime                             @updatedAt

  organisation   Organisation  @relation(fields: [organisation_id], references: [id])
  public_holiday PublicHoliday @relation(fields: [public_holiday_id], references: [id])

  @@unique([public_holiday_id, scope_type, scope_value])
  @@index([clerk_org_id])
  @@index([organisation_id])
  @@index([public_holiday_id])
  @@index([scope_type, scope_value])
  @@map("public_holiday_assignments")
}

model Feed {
  id              String      @id @default(uuid()) @db.Uuid
  clerk_org_id    String
  organisation_id String?     @db.Uuid
  name            String
  slug            String
  status          feed_status @default(active)
  privacy_default String      @default("named")
  scope_type      String      @default("all_staff")
  created_at      DateTime    @default(now())
  updated_at      DateTime    @updatedAt

  organisation Organisation? @relation(fields: [organisation_id], references: [id])
  scopes       FeedScope[]
  tokens       FeedToken[]

  @@unique([clerk_org_id, slug])
  @@index([clerk_org_id])
  @@index([organisation_id])
  @@map("feeds")
}

model FeedScope {
  id           String               @id @default(uuid()) @db.Uuid
  clerk_org_id String
  feed_id      String               @db.Uuid
  rule_type    feed_scope_rule_type
  rule_value   String
  created_at   DateTime             @default(now())
  updated_at   DateTime             @updatedAt

  feed Feed @relation(fields: [feed_id], references: [id])

  @@index([clerk_org_id])
  @@index([feed_id])
  @@index([rule_type, rule_value])
  @@map("feed_scopes")
}

model FeedToken {
  id           String            @id @default(uuid()) @db.Uuid
  clerk_org_id String
  feed_id      String            @db.Uuid
  token_hash   String            @unique
  token_hint   String
  status       feed_token_status @default(active)
  expires_at   DateTime?
  revoked_at   DateTime?
  created_at   DateTime          @default(now())
  updated_at   DateTime          @updatedAt

  feed Feed @relation(fields: [feed_id], references: [id])

  @@index([clerk_org_id])
  @@index([feed_id])
  @@map("feed_tokens")
}

model Notification {
  id                String            @id @default(uuid()) @db.Uuid
  clerk_org_id      String
  recipient_user_id String
  type              notification_type
  payload           Json
  is_read           Boolean           @default(false)
  created_at        DateTime          @default(now())
  updated_at        DateTime          @updatedAt

  @@index([clerk_org_id])
  @@index([recipient_user_id, is_read])
  @@index([recipient_user_id, created_at])
  @@map("notifications")
}

model NotificationPreference {
  id                String            @id @default(uuid()) @db.Uuid
  user_id           String
  clerk_org_id      String
  notification_type notification_type
  in_app_enabled    Boolean           @default(true)
  email_enabled     Boolean           @default(true)
  created_at        DateTime          @default(now())
  updated_at        DateTime          @updatedAt

  @@unique([user_id, clerk_org_id, notification_type])
  @@index([clerk_org_id])
  @@index([user_id])
  @@map("notification_preferences")
}

model SyncRun {
  id              String                 @id @default(uuid()) @db.Uuid
  clerk_org_id    String
  organisation_id String                 @db.Uuid
  xero_tenant_id  String?                @db.Uuid
  status          String
  entity_type     xero_sync_entity_type?
  records_synced  Int                    @default(0)
  records_failed  Int                    @default(0)
  error_message   String?
  started_at      DateTime
  completed_at    DateTime?
  created_at      DateTime               @default(now())
  updated_at      DateTime               @updatedAt

  organisation   Organisation   @relation(fields: [organisation_id], references: [id])
  failed_records FailedRecord[]

  @@index([clerk_org_id])
  @@index([organisation_id])
  @@index([organisation_id, started_at])
  @@map("sync_runs")
}

model FailedRecord {
  id              String                @id @default(uuid()) @db.Uuid
  clerk_org_id    String
  organisation_id String                @db.Uuid
  sync_run_id     String                @db.Uuid
  entity_type     xero_sync_entity_type
  source_id       String
  error_message   String
  raw_payload     Json?
  created_at      DateTime              @default(now())
  updated_at      DateTime              @updatedAt

  organisation Organisation @relation(fields: [organisation_id], references: [id])
  sync_run     SyncRun      @relation(fields: [sync_run_id], references: [id])

  @@index([clerk_org_id])
  @@index([organisation_id])
  @@index([sync_run_id])
  @@map("failed_records")
}

model AuditEvent {
  id              String   @id @default(uuid()) @db.Uuid
  clerk_org_id    String
  organisation_id String   @db.Uuid
  actor_user_id   String?
  action          String
  resource_type   String
  resource_id     String?
  payload         Json?
  created_at      DateTime @default(now())

  organisation Organisation @relation(fields: [organisation_id], references: [id])

  @@index([clerk_org_id])
  @@index([organisation_id])
  @@index([organisation_id, created_at])
  @@map("audit_events")
}
